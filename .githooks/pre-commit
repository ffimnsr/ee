#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"
test_summary_script="./scripts/test-workspace-summary.sh"

package_scope=()
scope_args=()
needs_rust_checks=0
needs_workspace_checks=0

add_scoped_package() {
    local package="$1"
    local existing

    if [[ "${package_scope[0]+set}" != "set" ]]; then
        package_scope=("$package")
        return
    fi

    for existing in "${package_scope[@]}"; do
        [[ "$existing" == "$package" ]] && return
    done

    package_scope+=("$package")
}

sorted_scoped_packages() {
    if [[ "${package_scope[0]+set}" != "set" ]]; then
        return
    fi

    printf '%s\n' "${package_scope[@]}" | sort -u
}

package_has_lib_target() {
    local package="$1"
    local manifest_path="crates/$package/Cargo.toml"

    [[ -f "$manifest_path" ]] || return 1

    if grep -Eq '^\[lib\]$' "$manifest_path"; then
        return 0
    fi

    [[ -f "crates/$package/src/lib.rs" ]]
}

run_stable_clippy() {
    local stable_targets_with_lib=(--lib --bins --tests --examples)
    local stable_targets_without_lib=(--bins --tests --examples)

    if [[ "${#scope_args[@]}" -eq 0 || "${scope_args[0]}" == "--workspace" ]]; then
        echo "[pre-commit] lint stable (${scope_args[*]})"
        cargo +stable clippy "${scope_args[@]}" "${stable_targets_with_lib[@]}" --all-features -- -D warnings
        return
    fi

    local packages_with_lib=()
    local packages_without_lib=()
    local package
    while IFS= read -r package; do
        [[ -z "$package" ]] && continue
        if package_has_lib_target "$package"; then
            packages_with_lib+=("$package")
        else
            packages_without_lib+=("$package")
        fi
    done < <(sorted_scoped_packages)

    local scoped_args=()

    if [[ "${packages_with_lib[0]+set}" == "set" ]]; then
        scoped_args=()
        for package in "${packages_with_lib[@]}"; do
            scoped_args+=(-p "$package")
        done
        echo "[pre-commit] lint stable (${scoped_args[*]})"
        cargo +stable clippy "${scoped_args[@]}" "${stable_targets_with_lib[@]}" --all-features -- -D warnings
    fi

    if [[ "${packages_without_lib[0]+set}" == "set" ]]; then
        scoped_args=()
        for package in "${packages_without_lib[@]}"; do
            scoped_args+=(-p "$package")
        done
        echo "[pre-commit] lint stable no-lib (${scoped_args[*]})"
        cargo +stable clippy "${scoped_args[@]}" "${stable_targets_without_lib[@]}" --all-features -- -D warnings
    fi
}

collect_check_scope() {
    local file
    while IFS= read -r file; do
        [[ -z "$file" ]] && continue

        case "$file" in
            *.rs|Cargo.toml|Cargo.lock|rustfmt.toml|crates/*/Cargo.toml|crates/*/build.rs|crates/*/src/*|crates/*/tests/*|crates/*/benches/*)
                needs_rust_checks=1
                ;;
            *)
                ;;
        esac

        case "$file" in
            Cargo.toml|Cargo.lock|rustfmt.toml)
                needs_workspace_checks=1
                ;;
            crates/*)
                local package_dir
                package_dir="${file#crates/}"
                package_dir="${package_dir%%/*}"
                if [[ -n "$package_dir" ]]; then
                    add_scoped_package "$package_dir"
                else
                    needs_workspace_checks=1
                fi
                ;;
            *.rs)
                needs_workspace_checks=1
                ;;
            *)
                ;;
        esac
    done < <(git diff --cached --name-only --diff-filter=ACMR)
}

build_scope_args() {
    if [[ "$needs_workspace_checks" -eq 1 || "${ATLAS_PRE_COMMIT_FULL:-0}" == "1" ]]; then
        scope_args=(--workspace)
        return
    fi

    local package
    while IFS= read -r package; do
        [[ -z "$package" ]] && continue
        scope_args+=(-p "$package")
    done < <(sorted_scoped_packages)
}

main() {
    collect_check_scope
    build_scope_args

    if [[ "$needs_rust_checks" -eq 1 || "${ATLAS_PRE_COMMIT_FULL:-0}" == "1" ]]; then
        echo "[pre-commit] format check"
        cargo fmt --all --check

        if [[ "${#scope_args[@]}" -eq 0 ]]; then
            scope_args=(--workspace)
        fi

        echo "[pre-commit] lint (${scope_args[*]})"
        cargo clippy "${scope_args[@]}" --all-targets --all-features -- -D warnings

        run_stable_clippy

        echo "[pre-commit] test stable (${scope_args[*]})"
        "$test_summary_script" +stable "${scope_args[@]}" --all-features
        echo "[pre-commit] test passed"
    else
        echo "[pre-commit] no Rust changes staged; skipping cargo fmt/clippy/test"
    fi

    # atlas-hook start

    # Installed by atlas. Remove these lines to disable atlas graph updates.
    if command -v atlas >/dev/null 2>&1; then
        atlas update || true
        atlas detect-changes || true
    fi
    echo "[pre-commit] complete"
    # atlas-hook end
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
    main "$@"
fi
