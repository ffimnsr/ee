{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EeToml",
  "description": "Raw `.ee.toml` shape; all fields optional so partial files work.",
  "type": "object",
  "properties": {
    "root": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "indent_style": {
      "description": "`\"spaces\"` or `\"tabs\"` (aliases: `\"space\"`, `\"tab\"`).",
      "type": [
        "string",
        "null"
      ]
    },
    "indent_size": {
      "description": "Number of spaces per indent level.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    },
    "tab_width": {
      "description": "Visual width of a hard-tab character.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    },
    "end_of_line": {
      "description": "`\"lf\"`, `\"crlf\"`, or `\"cr\"`.",
      "type": [
        "string",
        "null"
      ]
    },
    "charset": {
      "description": "Expected charset, e.g. `\"utf-8\"`.",
      "type": [
        "string",
        "null"
      ]
    },
    "trim_trailing_whitespace": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "insert_final_newline": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "number_style": {
      "description": "`\"absolute\"`, `\"relative\"`, or `\"relative_absolute\"`.",
      "type": [
        "string",
        "null"
      ]
    },
    "color_column": {
      "description": "Column position for the color column guide (e.g. `80`).  Omit to disable.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    },
    "show_visible_whitespace": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "scroll_offset": {
      "description": "Minimum rows between cursor and screen top/bottom edge.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint",
      "minimum": 0
    },
    "wrap_lines": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "sign_column": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "cursor_line": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "statusline_format": {
      "description": "`\"default\"` or `\"minimal\"`.",
      "type": [
        "string",
        "null"
      ]
    },
    "lsp": {
      "anyOf": [
        {
          "$ref": "#/$defs/LspToml"
        },
        {
          "type": "null"
        }
      ]
    },
    "languages": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/RuntimeLanguageConfig"
      },
      "default": {}
    },
    "keymap": {
      "anyOf": [
        {
          "$ref": "#/$defs/KeymapToml"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "LspToml": {
      "type": "object",
      "properties": {
        "servers": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/LspServerToml"
          }
        }
      },
      "additionalProperties": false
    },
    "LspServerToml": {
      "type": "object",
      "properties": {
        "language_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "command": {
          "type": [
            "string",
            "null"
          ]
        },
        "args": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "supports_single_file": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "workspace_identifier": {
          "type": [
            "string",
            "null"
          ]
        },
        "enabled": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "env": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "initialization_options": true
      },
      "additionalProperties": false
    },
    "RuntimeLanguageConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": [
            "boolean",
            "null"
          ],
          "default": null
        },
        "lsp": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null
        },
        "name": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "query_language": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "scope": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "content_regex": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "first_line_regex": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "injection_regex": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "aliases": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null
        },
        "file_types": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null
        },
        "globs": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null
        },
        "shebangs": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          },
          "default": null
        },
        "supported_query_kinds": {
          "type": [
            "array",
            "null"
          ],
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/RuntimeQueryKind"
          },
          "default": null
        },
        "match_priority": {
          "type": [
            "integer",
            "null"
          ],
          "format": "int32",
          "default": null
        },
        "grammar": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeGrammarConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "RuntimeQueryKind": {
      "type": "string",
      "enum": [
        "highlights",
        "injections",
        "locals",
        "tags",
        "textobjects",
        "indents",
        "folds",
        "rainbows"
      ]
    },
    "RuntimeGrammarConfig": {
      "type": "object",
      "properties": {
        "library": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "symbol": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "source": {
          "anyOf": [
            {
              "$ref": "#/$defs/RuntimeGrammarSource"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "RuntimeGrammarSource": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "crate": {
              "$ref": "#/$defs/RuntimeGrammarCrateSource"
            }
          },
          "required": [
            "crate"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "git": {
              "$ref": "#/$defs/RuntimeGrammarGitSource"
            }
          },
          "required": [
            "git"
          ],
          "additionalProperties": false
        }
      ]
    },
    "RuntimeGrammarCrateSource": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "version"
      ]
    },
    "RuntimeGrammarGitSource": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string"
        },
        "branch": {
          "type": [
            "string",
            "null"
          ]
        },
        "tag": {
          "type": [
            "string",
            "null"
          ]
        },
        "rev": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false,
      "oneOf": [
        {
          "properties": {
            "branch": {
              "type": "string"
            }
          },
          "required": [
            "branch"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "tag"
                ]
              },
              {
                "required": [
                  "rev"
                ]
              }
            ]
          }
        },
        {
          "properties": {
            "tag": {
              "type": "string"
            }
          },
          "required": [
            "tag"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "branch"
                ]
              },
              {
                "required": [
                  "rev"
                ]
              }
            ]
          }
        },
        {
          "properties": {
            "rev": {
              "type": "string"
            }
          },
          "required": [
            "rev"
          ],
          "not": {
            "anyOf": [
              {
                "required": [
                  "branch"
                ]
              },
              {
                "required": [
                  "tag"
                ]
              }
            ]
          }
        }
      ]
    },
    "KeymapToml": {
      "type": "object",
      "properties": {
        "inherit_defaults": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "sequence_timeout_ms": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0
        },
        "unbind": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KeyBindingTargetToml"
          }
        },
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KeyBindingEntryToml"
          }
        },
        "sequence_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/KeySequenceBindingToml"
          }
        }
      },
      "additionalProperties": false
    },
    "KeyBindingTargetToml": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "prefix": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "mode",
        "key"
      ]
    },
    "KeyBindingEntryToml": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "prefix": {
          "type": [
            "string",
            "null"
          ]
        },
        "action": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "mode",
        "key",
        "action"
      ]
    },
    "KeySequenceBindingToml": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "action": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "mode",
        "keys",
        "action"
      ]
    }
  }
}
